{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DailyTodoApp",
  "version": "2026.03.1",
  "identifier": "com.alihayder.dailytodoapp",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5005",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DailyTodoApp",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1Qzg2RUQ5QUJEQzRFMzAKUldRd1R0eXIyVzdJMWVlSUdxSlJwYThPN1hDNEZIeUtRL3Y3OGZmSEZhTHdFbW85QkpOK21UcEMK",
      "endpoints": [
        "https://github.com/ahayder/daily-todo/releases/latest/download/latest.json"
      ]
    }
  }
}
